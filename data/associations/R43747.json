        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Cet espace permet aux entrepreneurs de spectacles vivants établis dans un Etat membre de l’Union européenne ou partie à l’accord sur l’espace économique européen (EEE), hors France, "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "d’informer l’autorité compétente préalablement à une activité temporaire et occasionnelle sur le territoire français"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Une déclaration doit être faite pour "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "chaque représentation"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " ou "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "série"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " de représentations "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "identiques"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " (dans un "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "même lieu"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " ou en "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "tournée"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ") organisée en France."
                }
              ]
            },
            {
              "type": "element",
              "name": "ASavoir",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "À savoir"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Pour toute question sur la démarche, vous pouvez contacter la direction régionale des affaires culturelles ("
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "DRAC"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "/DAC) de la "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "région"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " dans laquelle la "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "première représentation"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " est prévue."
                    }
                  ]
                }
              ]
            }
