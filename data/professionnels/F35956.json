              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Entreprises en difficulté : désignation et instauration des tribunaux des activités économiques"
                }
              ]
            },
            {
              "type": "element",
              "name": "Source",
              "attributes": {
