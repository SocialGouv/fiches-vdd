        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R67013"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Personne morale (formes juridiques d'entreprise)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Groupement doté de la personnalité juridique. On distingue les personnes morales de droit public (État, collectivités territoriales, établissements publics, etc. ) et les personnes morales de droit privé (sociétés, groupements d'intérêt économique, associations, etc.)."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R67012"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Personne physique (formes juridiques d'entreprises)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Individu doté d’une identité civile, d’une capacité juridique et ayant des droits et obligations en son nom (ex : un dirigeant d’une société, entrepreneur individuel)."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R10269"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Voiture particulière (VP)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Véhicule à moteur, construit et conçu pour le transport de personnes, ayant au moins 4 roues, comportant, en plus du siège du conducteur, 8 places assises au maximum, et dont le poids total en charge autorisé (PTAC) est inférieur ou égal à 3,5 tonnes."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Reference",
              "attributes": {
                "type": "Texte de référence",
                "URL": "https://www.legifrance.gouv.fr/loda/id/JORFTEXT000020237165",
                "ID": "R20050"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Arrêté du 9 février 2009 relatif aux démarches d'immatriculation des véhicules"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
