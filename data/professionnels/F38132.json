        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "Non,"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " il n’est plus possible de bénéficier du bonus écologique. Il a été supprimé depuis le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "2 décembre 2024"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " pour les "
                },
                {
                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R67013",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "personnes morales"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " et depuis le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "1"
                    },
                    {
                      "type": "element",
                      "name": "Exposant",
                      "children": [
                        {
                          "type": "text",
                          "text": "er"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " juillet 2025"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " pour les voitures particulières achetées ou louées par des "
                },
                {
                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R67012",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "personnes physiques"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "bonus écologique"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " était une "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "aide à l'achat ou à la location longue durée de véhicules propres"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " (utilisant l'électricité, l'hydrogène ou une combinaison des 2 comme source exclusive d'énergie) pouvant être attribué à toute entreprise domiciliée en France."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Il prenait la forme d'un versement au montant variable ou d'une déduction sur le coût de l'achat ou de la location du véhicule. Il s'appliquait uniquement aux "
                },
                {
                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R10269",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "voitures particulières"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            }
          ]
        },
