              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Décret n° 2025-606 du 30 juin 2025 relatif aux aides à l'achat ou à la location de véhicules peu polluants"
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "text",
                  "text": "Suppression du bonus écologique"
                }
