                    },
                    {
                      "type": "text",
                      "text": " ont l’obligation de déclarer et payer "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "2 acomptes"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " de CVAE au cours de l’année d’imposition."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Ces acomptes représentent chacun "
                },
                {
                  "type": "element",
                  "name": "Valeur",
                  "children": [
                    {
                      "type": "text",
                      "text": "50 %"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " du montant de CVAE due au titre de l’année d’imposition, et doivent être versés avant le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "15 juin"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " puis avant le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "15 septembre"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " de cette même année."
                }
              ]
            },
            {
              "type": "element",
              "name": "Attention",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Attention"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Ce formulaire est proposé "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "à titre indicatif"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": ". Les entreprises ont en effet l’obligation d’effectuer leurs déclaration et paiements relatifs à la CVAE de manière "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "dématérialisée"
