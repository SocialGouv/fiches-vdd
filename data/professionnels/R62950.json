                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Ce portail permet à l’entreprise d’effectuer différentes démarches :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Rechercher des projets d'achats en allant dans « recherche avancée » puis en sélectionnant le filtre « entité acheteuse »."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Configurer des alertes pour être informé de nouveaux projets d’achats dans son domaine d’activité"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "« Rechercher des partenaires » pour identifier aisément d’autres entreprises avec lesquelles constituer un groupement pour répondre aux appels d’offres intéressant l’entreprise"
                        }
                      ]
                    }
                  ]
                }
