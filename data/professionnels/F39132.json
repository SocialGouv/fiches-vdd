        {
          "type": "element",
          "name": "Introduction",
          "children": [
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Avant de recruter, il peut être utile pour le chef d’entreprise d'évaluer le coût précis que représente l’embauche d’un salarié pour la structure, et d'avoir connaissance des obligations nouvelles auxquelles il pourrait éventuellement être tenu."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Nous vous présentons les outils qui peuvent aider à se projeter."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "ListeSituations",
          "attributes": {
            "affichage": "onglet"
          },
          "children": [
            {
              "type": "element",
              "name": "Situation",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Embauche d’un premier salarié"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Texte",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le salaire, et tous les compléments versés au salarié, sont soumis aux cotisations et contributions de sécurité sociale. Elles sont calculées et payées par l’employeur."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le chef d’entreprise qui envisage de recruter peut utiliser cet outil pour "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "estimer le coût total de la rémunération"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " pour l’entreprise, ainsi que les "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "montants des cotisations patronales et salariales"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "ServiceEnLigne",
                      "attributes": {
                        "ID": "R45531",
                        "URL": "https://www.urssaf.fr/accueil/outils-documentation/simulateurs/cotisations-employeur.html",
                        "audience": "Professionnels",
                        "type": "Simulateur"
                      },
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Simulateur du coût d'embauche"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Source",
                          "attributes": {
                            "ID": "R30625"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Urssaf"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le montant du salaire est déterminé d’un "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "commun accord"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Employeur et salarié sont libres de fixer le salaire de base et les avantages et compléments éventuels, à condition de respecter le "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R31127",
                            "type": "Acronyme"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Smic"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " ("
                        },
                        {
                          "type": "element",
                          "name": "Valeur",
                          "children": [
                            {
                              "type": "text",
                              "text": "1 823,03 €"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " brut mensuel, base 35 heures par semaine), qui représente le "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "minimum légal"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ", ou le "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "salaire minima prévu par les conventions ou accords collectifs"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " qui s’appliquent à l'entreprise, s’il est supérieur."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Exemple",
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Exemple"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Le salaire mensuel minimum brut de la branche professionnelle de la coiffure est plus élévé que le "
                            },
                            {
                              "type": "element",
                              "name": "LienInterne",
                              "attributes": {
                                "LienPublication": "R31127",
                                "type": "Acronyme"
                              },
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Smic"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "text": ", c’est donc ce montant, plus favorable pour le salarié, qui doit être respecté."
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Un simulateur développé par le ministère du Travail facilite la recherche de la convention collective applicable : "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "element",
                              "name": "LienInterne",
                              "attributes": {
                                "LienPublication": "F36056",
                                "type": "Fiche Question-réponse conditionnée",
                                "audience": "Professionnels"
                              },
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Comment trouver sa convention collective lors de l'embauche d'un premier salarié ?"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Pour connaître le salaire minimum à respecter ("
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R31127",
                            "type": "Acronyme"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Smic"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " ou salaire minimum conventionnel), consultez la fiche "
                        },
                        {
                          "type": "element",
                          "name": "LienExterne",
                          "attributes": {
                            "URL": "https://code.travail.gouv.fr/contribution/quel-est-le-salaire-minimum?q=salaire%20minimum"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Quel est le salaire minimum ?"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " sur le site du Code du travail numérique."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "L’employeur doit en outre respecter les principes suivants :"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Liste",
                      "attributes": {
                        "type": "puce"
                      },
                      "children": [
                        {
                          "type": "element",
                          "name": "Item",
                          "children": [
                            {
                              "type": "element",
                              "name": "Paragraphe",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Égalité de rémunération entre femmes et hommes"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Item",
                          "children": [
                            {
                              "type": "element",
                              "name": "Paragraphe",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Non-discrimination selon les salariés."
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Lien",
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Référence : Code du travail : articles L3231-2 à L3231-3"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "LienExterne",
                          "attributes": {
                            "type": "Texte de référence",
                            "URL": "https://www.legifrance.gouv.fr/codes/id/LEGISCTA000006189663"
                          }
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Lien",
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Référence : Code du travail : article L2253-1"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "LienExterne",
                          "attributes": {
                            "type": "Texte de référence",
                            "URL": "https://www.legifrance.gouv.fr/codes/article_lc/LEGIARTI000036761771"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Situation",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Incidence de l’embauche d’un nouveau salarié"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Texte",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Pour anticiper les impacts d’une nouvelle embauche, l’employeur peut s’informer sur les obligations supplémentaires que cette embauche pourrait engendrer."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Ce simulateur recense les "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "obligations"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " à remplir par l'entreprise selon son effectif salarié et celles qui pourraient s'y ajouter "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "du fait de l’embauche de nouveaux salariés"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " :"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "ServiceEnLigne",
                      "attributes": {
