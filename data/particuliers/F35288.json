            }
          ]
        },
        {
          "type": "element",
          "name": "DossierPere",
          "attributes": {
            "ID": "N31341"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Assemblée générale des copropriétaires"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F2615"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Convocation"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F2619"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Déroulement"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F2636"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Compte-rendu"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "Oui"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", il est possible de contester une décision prise en assemblée générale. Il faut néanmoins respecter les conditions suivantes :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Être titulaire d’un "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R53028",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "droit réel"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " sur un "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R38693",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "lot"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " au moment de la tenue de l’assemblée générale (propriétaire, "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R58072",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "usufruitier"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ", etc.)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Être opposant (c’est-à-dire avoir voté « contre » la résolution adoptée ou « pour » une résolution qui a été rejetée) ou défaillant (c’est-à-dire être absent et non représenté lors du vote de la résolution). Le fait d’être opposant s’apprécie "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R71024",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "résolution"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " par résolution. Le copropriétaire qui était défaillant ou opposant à l’ensemble des résolutions peut demander l’"
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "annulation de l’assemblée générale dans son entier"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Agir en justice dans le "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "délai de 2 mois"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " à partir de la "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R14732",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "notification"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " du "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F2636",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "procès-verbal d’assemblée générale"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " par le "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F2608",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "syndic."
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " Si le syndic n’a jamais envoyé le procès-verbal, le délai de contestation est de "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "5 ans"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ". Dans tous les cas, le recours est effectué "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F20851",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "devant le tribunal judiciaire du lieu de situation de l'immeuble"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ". L’accompagnement par un avocat est obligatoire. Il fera délivrer une "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R12538",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "assignation"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " à l’encontre auprès du "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F2606",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "syndicat des copropriétaires"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " représenté par le syndic."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Contester une question soumise à la délibération de l’assemblée générale et aux votes des copropriétaires."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "ASavoir",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "À savoir"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "En l’absence de contestation dans les délais, une décision, même irrégulière ou illégale, devient définitive et s’impose à tous."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Les motifs de contestations sont très variés. Par exemple, il peut s’agir des cas suivants :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Irrégularités de "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F2615",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "convocation de l’assemblée générale"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " (délai, contenu, auteur incompétent etc.)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Irrégularités de composition de l’assemblée générale (personnes sans qualité ayant voté, absence de désignation du président de séance etc.)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Violation des "
                        },
                        {
                          "type": "element",
                          "name": "LienExterne",
                          "attributes": {
                            "URL": "http://www.inc-conso.fr/content/copropriete-les-majorites-de-vote-lors-dune-assemblee-generale"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "règles de majorité"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " applicables à la résolution"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Vote d’une question non inscrite à l’"
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R71026",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "ordre du jour"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " de l’assemblée générale."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Il suffit de démontrer que les règles, prévues par la loi, concernant l'organisation ou le fonctionnement de l'assemblée générale ou la décision en elle-même, n'ont pas été respectées."
                }
              ]
            },
            {
              "type": "element",
              "name": "ANoter",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "À noter"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Il n'est pas nécessaire de justifier d'un préjudice particulier pour contester une décision prise en méconnaissance de la loi."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "En principe, si le tribunal annule une décision d’assemblée générale ou l’assemblée générale, elle est considérée comme n’ayant jamais existé. Cette décision s’impose à tous les copropriétaires, y compris ceux qui n’ont pas agi en justice."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Toutefois, l’annulation n’a pas d’impact sur l’"
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "N31064",
                    "type": "Dossier",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "obligation de régler les charges"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " de chaque copropriétaire. De même, en cas d’annulation de la désignation du syndic, les actes passés avec des tiers de bonne foi restent valables."
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "QuiPeutMAider",
          "attributes": {
            "ID": "R55753",
            "sve": "non",
            "type": "Local personnalisé sur SP"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "France Services / Maison de services au public"
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "text",
                  "text": "Pour tout renseignement complémentaire"
                }
              ]
            },
            {
              "type": "element",
              "name": "PivotLocal",
              "children": [
                {
                  "type": "text",
                  "text": "france_services"
                }
              ]
            },
            {
              "type": "element",
              "name": "RessourceWeb",
              "attributes": {
                "URL": "https://lannuaire.service-public.gouv.fr/navigation/france_services"
              }
            }
          ]
        },
        {
          "type": "element",
          "name": "Reference",
          "attributes": {
            "type": "Texte de référence",
            "URL": "https://www.legifrance.gouv.fr/loda/article_lc/LEGIARTI000039329680",
            "ID": "R32730"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Loi n°65-557 du 10 juillet 1965 : article 42"
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "text",
                  "text": "Délai pour contester une décision"
