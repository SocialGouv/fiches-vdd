                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R42218",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "l'Espace économique européen (EEE)"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " ou Suisse :"
