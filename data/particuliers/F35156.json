                {
                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R41270",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "l'Union européenne"
