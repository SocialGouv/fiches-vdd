        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Les parents ont le devoir de veiller au respect de la vie privée de leur enfant. Ils exercent en commun l’autorité parentale. Mais il est possible que l’autorité parentale soit exercée par un seul des parents. C’est par exemple le cas "
                },
                {
                  "type": "element",
                  "name": "Expression",
                  "children": [
                    {
                      "type": "text",
                      "text": "d’une famille monoparentale"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "BlocCas",
              "attributes": {
                "affichage": "radio"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Cas",
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "Exercice de l’autorité par les 2 parents"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "C'est aux parents de protéger "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "en commun "
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "le droit à l'image de leur enfant mineur, dans le respect du droit à sa vie privée."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "À titre d'exemple, les parents doivent "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "surveiller la diffusion de photos ou de vidéos"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " sur internet et en particulier sur les réseaux sociaux."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Les parents doivent associer l'enfant à l'exercice de son droit à l'image, selon son âge et son degré de maturité."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Si l'un des parents ne respecte pas le droit à l’image de l'enfant, l'autre parent peut saisir le "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R45626",
                            "type": "Sigle"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Jaf"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " dont dépend la résidence habituelle de l'enfant. Le juge peut interdire au parent de publier ou diffuser l’image de l’enfant sans l’accord de l’autre parent."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le parent qui diffuserait une image de l'enfant mineur peut être condamné à des "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R12532",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "dommages et intérêts"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " s'il a causé un préjudice à son enfant."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Lorsque la diffusion de l’image de l’enfant par ses parents porte atteinte à sa dignité ou sa moralité, le juge peut "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F3134",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "déléguer l’exercice du droit à l’image"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Cas",
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "Exercice de l’autorité parentale par un seul parent"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "C'est à ce parent de protéger "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "seul"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " le droit à l'image de son enfant mineur, dans le respect du droit à sa vie privée."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Si ce parent ne respecte pas le droit à l’image de l'enfant, le "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R45626",
                            "type": "Sigle"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "Jaf"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " dont dépend la résidence habituelle de l'enfant peut être saisi par un tiers (un membre de la famille ou un professionnel)."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le juge peut interdire au parent de publier ou diffuser l’image de l’enfant."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le parent qui diffuserait une image de l'enfant mineur peut être condamné à des "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R12532",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "dommages et intérêts"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " s'il a causé un préjudice à son enfant."
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Lorsque la diffusion de l’image de l’enfant par ce parent porte atteinte à sa dignité ou sa moralité, le juge peut "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F3134",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "déléguer l’exercice du droit à l’image"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
