                {
                  "type": "text",
                  "text": "Responsabilité par son fait, sa négligence ou son imprudence (article 1241)"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Reference",
          "attributes": {
            "type": "Texte de référence",
            "URL": "https://www.legifrance.gouv.fr/loda/id/LEGITEXT000006070308/2021-06-18/",
            "ID": "R59617"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Arrêté du 20 novembre 1979 portant règlement sanitaire du département de Paris"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R53142"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Destination d'un immeuble"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Correspond à ce pour quoi un immeuble a été construit. Par exemple : usage d'habitation, usage professionnel ou usage mixte (immeuble d'habitation abritant également des locaux professionnels)."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R57067"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Plan local d'urbanisme (PLU)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Document communal d'urbanisme qui détermine les conditions d'aménagement et d'utilisation des sols. Il définit, pour chaque terrain, les règles d'urbanisme applicables."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
