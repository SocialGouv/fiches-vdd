                {
                  "type": "text",
                  "text": "Limitation du règlement de copropriété"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Reference",
          "attributes": {
            "type": "Texte de référence",
            "URL": "https://www.legifrance.gouv.fr/codes/id/LEGISCTA000032021488/",
