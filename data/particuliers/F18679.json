                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Faire refabriquer une ou des nouvelles plaques"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Après avoir porté plainte, vous devez faire refaire auprès d'un professionnel la ou les plaques comportant le numéro d'immatriculation figurant sur votre certificat d’immatriculation (auparavant appelé "
                    },
                    {
                      "type": "element",
                      "name": "Expression",
                      "children": [
                        {
                          "type": "text",
                          "text": "carte grise"
                        }
