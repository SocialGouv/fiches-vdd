                          "type": "text",
                          "text": "Attention"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Si vous circulez avec un véhicule qui n’a pas de plaques d'immatriculation, vous pouvez être sanctionné d'une amende pouvant aller jusqu'à "
                        },
                        {
                          "type": "element",
                          "name": "Valeur",
                          "children": [
