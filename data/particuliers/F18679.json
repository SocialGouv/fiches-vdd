                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Poser ou faire poser la ou les nouvelles plaques"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Une fois la ou les nouvelles plaques d’immatriculation refabriquées, vous devez les fixer ou les faire fixer sur votre véhicule."
                    }
                  ]
                },
                {
                  "type": "element",
