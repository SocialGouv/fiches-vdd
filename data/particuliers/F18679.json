                          "type": "text",
                          "text": "À savoir"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le vol de plaques n'est pas assimilé à "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F34375",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "l'usurpation du numéro d'immatriculation"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ". Si vos plaques sont volées sans preuve d’usurpation, vous n'obtenez pas un nouveau numéro d'immatriculation du véhicule."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
