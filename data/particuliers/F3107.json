              }
            }
          ]
        },
        {
          "type": "element",
          "name": "Reference",
          "attributes": {
            "type": "Texte de référence",
            "URL": "https://www.legifrance.gouv.fr/loda/article_lc/LEGIARTI000041587248",
            "ID": "R33845"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
