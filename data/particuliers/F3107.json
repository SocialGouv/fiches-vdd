                      "children": [
                        {
                          "type": "text",
                          "text": "Logement"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "QuiPeutMAider",
          "attributes": {
            "ID": "R55753",
            "sve": "non",
            "type": "Local personnalisé sur SP"
          },
          "children": [
            {
              "type": "element",
