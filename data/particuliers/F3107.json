                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R51499"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Changement de destination"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Il existe 5 types de destinations : exploitation agricole et forestière, habitation, commerce et activités de service, équipements d'intérêt collectif et services publics, autres activités des secteurs secondaire ou tertiaire. Il y a changement de destination lorsque l'on passe d'une catégorie à une autre."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Reference",
              "attributes": {
                "type": "Texte de référence",
                "URL": "https://www.legifrance.gouv.fr/codes/id/LEGISCTA000031720595/",
                "ID": "R51500"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Code de l'urbanisme : articles R151-27 à R151-29"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R45570"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Clause d'habitation bourgeoise exclusive"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Logement pouvant servir pour l'habitation et/ou la domiciliation du siège d'une entreprise, même commerciale. En revanche, il est interdit d'y exercer toute activité professionnelle (installer un commerce ou un atelier, un cabinet pour une profession libérale, ou faire d'un logement une location meublée de courte durée)."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Definition",
          "attributes": {
            "ID": "R44507"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Parties privatives d'une copropriété"
                }
              ]
            },
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Parties des bâtiments (porte d'entrée, salon, salle de bains...) et des terrains réservés à l'usage exclusif d'un copropriétaire"
                    }
                  ]
                }
              ]
            }
          ]
        },
