              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Partie de bâtiment comportant obligatoirement une partie privative et une quote-part de parties communes"
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Reference",
              "attributes": {
                "type": "Texte de référence",
                "URL": "https://www.legifrance.gouv.fr/loda/id/LEGITEXT000006068256/",
