                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Le "
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "F2589",
                    "type": "Fiche d'information conditionnée",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "règlement de copropriété"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " donne une affectation (appartement, boutique, cave, parking, grenier etc.) à chaque "
                },
                {
                  "type": "element",
                  "name": "LienIntra",
                  "attributes": {
                    "LienID": "R38693",
                    "type": "Définition de glossaire"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "lot"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " dans l’immeuble en copropriété."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Un copropriétaire peut, en principe, modifier l’affectation de son lot. Pour cela, il faut que ce changement respecte les 3 points suivants :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "La "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R51499",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "destination de l'immeuble"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " fixée par le règlement de copropriété"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Les droits des autres copropriétaires. Par exemple, ce changement ne doit pas occasionner de "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F31117",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "nuisances sonores"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " ou "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "F19299",
                            "type": "Fiche d'information conditionnée",
                            "audience": "Particuliers"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "olfactives"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " à l'égard des autres copropriétaires, ou entrainer une surfréquentation de l’immeuble ou porter atteinte à la sécurité des occupants"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Et les clauses du règlement de copropriété ("
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R45570",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "clause d’habitation bourgeoise exclusive"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ", clauses interdisant certains commerces, etc.)."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Exemple",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Exemple"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Liste",
                  "attributes": {
                    "type": "puce"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Passage d’un local commercial à un usage d’habitation, dès lors que la destination de l’immeuble (par exemple mixte habitation/commerce) le permet et que les autres copropriétaires ne subissent pas de préjudice"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Création d’un emplacement de stationnement dans un jardin privatif, autorisée par la destination de l’immeuble (usage d’habitation avec possibilité d’exercer une profession libérale)"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Dans ces cas, le copropriétaire n’a pas à obtenir l’autorisation du "
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "F2606",
                    "type": "Fiche d'information conditionnée",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "syndicat des copropriétaires"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Toutefois, le changement d’affectation est "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "soumis à l’autorisation de l’assemblée générale"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " lorsque le changement d’affectation :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Entraîne des travaux important (transformation d’un débarras ou grenier en pièce d’habitation, transformation d’une terrasse ou de comble en appartement)"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Ou affecte les parties communes ou l’aspect extérieur de l’immeuble"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Ou entraine une modification du règlement de copropriété (changement de destination contractuelle du lot ou de l’immeuble),"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Pour les copropriétaires "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "habitant dans le 92, 93 ou 94 ou dans une ville de plus de 200 000 habitants"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", il faut obtenir une "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "autorisation préalable"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " de la mairie"
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": " pour changer l'affectation des locaux destinés à l'habitation"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ". Une délibération du conseil municipal fixe les conditions de délivrance de cette autorisation. Pour connaître ces conditions, il est nécessaire de contacter la mairie (ou consulter le règlement municipal parfois disponible sur son site internet)."
                }
              ]
            },
            {
              "type": "element",
              "name": "OuSAdresser",
              "attributes": {
                "ID": "R1",
                "sve": "non",
                "type": "Local personnalisé sur SP"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Mairie"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "PivotLocal",
                  "children": [
                    {
                      "type": "text",
                      "text": "mairie"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "RessourceWeb",
                  "attributes": {
                    "URL": "https://lannuaire.service-public.gouv.fr/navigation/mairie"
                  }
                }
              ]
            },
            {
              "type": "element",
              "name": "ASavoir",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "À savoir"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le changement d’affectation d’une "
                    },
                    {
                      "type": "element",
                      "name": "LienIntra",
                      "attributes": {
                        "LienID": "R44507",
                        "type": "Définition de glossaire"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "partie privative"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " peut entraîner une "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "modification de la répartition des charges"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " de copropriété, dès lors qu’il a une incidence sur l’usage des parties communes ou sur les services collectifs. Cette situation peut ainsi conduire à une "
                    },
                    {
                      "type": "element",
                      "name": "MiseEnEvidence",
                      "children": [
                        {
                          "type": "text",
                          "text": "révision des "
                        },
                        {
                          "type": "element",
                          "name": "LienIntra",
                          "attributes": {
                            "LienID": "R53506",
                            "type": "Définition de glossaire"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "tantièmes"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " de charges afin de tenir compte de cette nouvelle affectation."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "VoirAussi",
          "attributes": {
            "important": "non"
          },
          "children": [
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F2589",
                "audience": "Particuliers"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Règlement de copropriété"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Theme",
                  "attributes": {
                    "ID": "N19808"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "Logement"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F31518",
                "audience": "Particuliers"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Partie commune réservée à l'usage exclusif d'un copropriétaire (droit de jouissance privatif)"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Theme",
                  "attributes": {
                    "ID": "N19808"
                  },
                  "children": [
                    {
                      "type": "element",
