                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F10403"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Offre de contrat de travail et promesse d'embauche unilatérale"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Introduction",
          "children": [
            {
              "type": "element",
              "name": "Texte",
              "children": [
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Un groupement d’employeurs peut être constitué entre plusieurs entreprises afin d’embaucher des salariés et de les mettre à disposition de ses membres. Le groupement d’employeurs doit respecter certaines conditions et règles. Nous vous expliquons la réglementation en vigueur."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Chapitre",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Que doit contenir le contrat de travail d’un salarié embauché par un groupement d’employeurs ?"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Un salarié peut signer un contrat de travail directement auprès d'un groupement d'employeurs."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le contrat de travail doit mentionner tous les éléments suivants :"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Liste",
                  "attributes": {
                    "type": "puce"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Conditions d'emploi et de rémunération du salarié"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Qualification professionnelle du salarié"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Liste des entreprises dans lesquelles le salarié est amené à travailler"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Lieux d'exécution du travail."
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le contrat de travail est conclu entre le salarié et l’employeur qui préside le groupement."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "ANoter",
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "À noter"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Le contrat de travail peut être un "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R24389",
                            "type": "Sigle"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "CDI"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "  ou un "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
                            "LienPublication": "R2454",
                            "type": "Sigle"
                          },
                          "children": [
                            {
                              "type": "text",
                              "text": "CDD"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ", à temps plein ou à temps partiel. En principe, c’est un CDI à temps plein qui est proposé au salarié d’un groupement d’employeurs en vue de stabiliser son emploi."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Chapitre",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Quelle est la rémunération d’un salarié embauché par un groupement d’employeurs ?"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le salarié est rémunéré par le groupement d'employeurs."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le salarié bénéficie de l'égalité de traitement par rapport aux autres salariés des entreprises auprès desquelles il est mis à disposition (rémunération, "
                    },
                    {
                      "type": "element",
                      "name": "LienInterne",
                      "attributes": {
                        "LienPublication": "F2140",
                        "type": "Fiche d'information conditionnée",
                        "audience": "Particuliers"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "intéressement"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": ", "
                    },
                    {
                      "type": "element",
                      "name": "LienInterne",
                      "attributes": {
                        "LienPublication": "F2141",
                        "type": "Fiche d'information conditionnée",
                        "audience": "Particuliers"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "participation"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " et épargne salariale)."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "La rémunération perçue par un salarié du groupement d'employeurs ne peut pas être inférieure à celle que perçoit dans l'entreprise utilisatrice un salarié de qualification équivalente, occupant le même poste."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Chapitre",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Quels sont les droits et obligations d’un salarié embauché par un groupement d’employeurs ?"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le salarié d’un groupement d’employeurs peut, par exemple, travailler sur une période de 1, 2 ou 3 jours dans une entreprise puis travailler sur une autre période de plusieurs jours dans une autre entreprise. C’est l’employeur qui préside le groupement qui fixe le planning de travail du salarié."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le salarié du groupement a accès aux moyens de transport collectifs et aux installations collectives (restauration notamment) dans les mêmes conditions que les salariés de l'entreprise."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Le salarié du groupement a accès au "
                    },
                    {
                      "type": "element",
                      "name": "LienInterne",
                      "attributes": {
                        "LienPublication": "F2211",
                        "type": "Fiche d'information conditionnée",
                        "audience": "Particuliers"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "suivi médical"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " dans les mêmes conditions que les salariés de l'entreprise."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Si l'un des employeurs quitte le groupement, cela entraîne une modification par "
                    },
                    {
                      "type": "element",
                      "name": "LienIntra",
                      "attributes": {
                        "LienID": "R10829",
                        "type": "Définition de glossaire"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "avenant"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " du contrat de travail du salarié. L’employeur qui préside le groupement doit rédiger l’avenant au contrat de travail."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "La rupture du contrat de travail d’un salarié d’un groupement d’employeurs en CDD s’effectue dans les "
                    },
                    {
                      "type": "element",
                      "name": "LienInterne",
                      "attributes": {
                        "LienPublication": "F40",
                        "type": "Fiche d'information conditionnée",
                        "audience": "Particuliers"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "conditions habituelles"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "En cas de faute du salarié, le pouvoir disciplinaire est à la charge du groupement d'employeurs."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Reference",
          "attributes": {
            "type": "Texte de référence",
