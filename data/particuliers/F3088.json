          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Chômage : aides à la formation"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F12382"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Compte personnel de formation (CPF)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F291"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Allocation d'aide au retour à l'emploi formation (Aref)"
                }
              ]
            },
            {
              "type": "element",
              "name": "Fiche",
              "attributes": {
                "ID": "F292"
              },
              "children": [
                {
                  "type": "text",
                  "text": "Rémunération de fin de formation (RFF)"
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "Texte",
          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Oui. Pendant votre période de chômage, que vous soyez "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "indemnisé ou non"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", vous pouvez demander à votre conseiller France Travail (anciennement Pôle emploi) à bénéficier d'un "
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "F3087",
                    "type": "Fiche d'information conditionnée",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "bilan de compétences"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Vous pouvez contacter votre conseiller."
                }
              ]
            },
            {
              "type": "element",
              "name": "OuSAdresser",
              "attributes": {
                "ID": "R194",
                "sve": "non",
                "type": "Local personnalisé sur SP"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "France Travail"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "PivotLocal",
                  "children": [
                    {
                      "type": "text",
                      "text": "france_travail"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "RessourceWeb",
                  "attributes": {
                    "URL": "https://www.francetravail.fr/annuaire/"
                  }
                },
                {
                  "type": "element",
                  "name": "Source",
                  "attributes": {
                    "ID": "R30668"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "France Travail"
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Un outil, élaboré par France Travail, existe pour vérifier :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Que vos compétences correspondent à celles recherchées par les employeurs"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Ou que l’emploi vers lequel vous vous dirigez vous convient."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Il s'agit de"
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": " l'évaluation des compétences et des capacités professionnelles (ECCP)"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ". Elle permet :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "D’évaluer les compétences et connaissances correspondant à un métier"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "D'aider à identifier d'autres fonctions ou secteurs sur lesquels vous pourriez vous positionner en utilisant les compétences acquises auparavant."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Pendant une demi-journée ou une journée, un prestataire sélectionné par France Travail vous fait passer des tests. Ce prestataire :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Dresse un bilan de vos acquis professionnels"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Isole vos points forts"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Vous explique comment les faire valoir auprès d’employeurs potentiels"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Et met éventuellement en place un plan d’action pour préciser vos besoins de formation."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "En savoir plus sur l’utilisation du compte personnel de formation (CPF) pour le bilan de compétences"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Vous pouvez utiliser votre "
                    },
                    {
                      "type": "element",
                      "name": "LienInterne",
                      "attributes": {
                        "LienPublication": "F10705",
                        "type": "Fiche d'information conditionnée",
                        "audience": "Particuliers"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "CPF"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " pour accéder à un bilan de compétences si vous répondez aux 2 conditions suivantes :"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Liste",
                  "attributes": {
                    "type": "puce"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Vous n’avez pas bénéficié d’un bilan financé par les fonds publics (exemples : "
                            },
                            {
                              "type": "element",
                              "name": "LienInterne",
                              "attributes": {
                                "LienPublication": "R53312",
                                "type": "Acronyme"
                              },
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Opco"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "text": ", France Travail, "
                            },
                            {
                              "type": "element",
                              "name": "LienInterne",
                              "attributes": {
                                "LienPublication": "R52427",
                                "type": "Acronyme"
                              },
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Agefiph"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "text": ", Caisse des dépôts et consignations) au cours des 5 dernières années"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Item",
                      "children": [
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Vous mobilisez au maximum "
                            },
                            {
                              "type": "element",
                              "name": "Valeur",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "1 600 €"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "text": " inscrits sur votre CPF. Ce plafonnement s’établit sur les droits CPF issus de l’alimentation annuelle "
                            },
                            {
                              "type": "element",
                              "name": "MiseEnEvidence",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "et non"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "text": " sur les éventuels co-financements."
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "ASavoir",
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "À savoir"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Seules les heures d'accompagnement réalisées par un prestataire peuvent donner lieu à un financement par la mobilisation des droits inscrits sur le CPF."
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
