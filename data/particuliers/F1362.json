              "children": [
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "Tout"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "F39103",
                    "type": "Fiche Question-réponse conditionnée",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "véhicule terrestre à moteur"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " doit être "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "assuré"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "même lorsqu’il ne circule pas"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Jusqu’au 1"
                },
                {
                  "type": "element",
                  "name": "Exposant",
                  "children": [
                    {
                      "type": "text",
                      "text": "er"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " avril 2024, la preuve d’assurance se faisait avec la "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "carte verte"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", composée d’une attestation conservée dans le véhicule et d’un certificat apposé sur le pare-brise."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Depuis le 1"
                },
                {
                  "type": "element",
                  "name": "Exposant",
                  "children": [
                    {
                      "type": "text",
                      "text": "er"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " avril 2024, la carte verte (attestation + certificat apposé sur le véhicule) "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "n’est plus délivrée, ni exigée comme justificatif pour les véhicules immatriculés"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ". La preuve d’assurance se fait désormais par le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "Fichier des véhicules assurés (FVA)"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " ou, temporairement par le "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "document remis par l’assureur lors de la souscription"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": ", valable 15 jours."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Pour les "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "véhicules non immatriculés soumis à l’assurance"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " (par exemple, cyclomobiles légers, EDPM, tondeuses autoportées) :"
                }
              ]
            },
            {
              "type": "element",
              "name": "Liste",
              "attributes": {
                "type": "puce"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "La carte verte continue d’être délivrée, mais elle est imprimée sur papier blanc."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Vous devez "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "apposer un certificat d’assurance sur le véhicule"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " dans les 15 jours qui suivent la souscription ou le renouvellement du contrat. Ce certificat indique notamment le "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "numéro de châssis"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " et les "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "dates de validité"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " du contrat. Si le certificat définitif n’est pas encore disponible, l’assureur peut vous fournir un "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "certificat provisoire"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Item",
                  "children": [
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "Lors d’un contrôle, "
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "vous devez pouvoir présenter une "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "attestation d’assurance"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " (ou attestation provisoire, ou, pour les déplacements à l’étranger, une "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "carte internationale d’assurance"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ". Si vous n’êtes pas en mesure de présenter un document valide, vous devez payer une "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "amende de "
                            },
                            {
                              "type": "element",
                              "name": "Valeur",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "35 €"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": ". La police peut vous accorder "
                        },
                        {
                          "type": "element",
                          "name": "MiseEnEvidence",
                          "children": [
                            {
                              "type": "text",
                              "text": "5 jours"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": " pour présenter un justificatif."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Savoir comment vérifier que le véhicule est enregistré dans le FVA"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "Vous pouvez vérifier que votre véhicule est bien enregistré comme assuré dans le fichier des véhicules assurés (FVA). Cette vérification peut être effectuée en renseignant le numéro d’immatriculation du véhicule ou certaines informations figurant sur le certificat d’immatriculation ou le contrat d’assurance."
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "ServiceEnLigne",
                  "attributes": {
                    "ID": "R68039",
                    "URL": "https://www.consultation-fva.fr/",
                    "audience": "Particuliers",
                    "type": "Téléservice"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "Interrogation du Fichier des véhicules assurés"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Source",
                      "attributes": {
                        "ID": "R50820"
                      },
                      "children": [
                        {
                          "type": "text",
                          "text": "Agira"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
