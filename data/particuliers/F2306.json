          "children": [
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Oui, l'employeur peut accorder, dans le cadre du "
                },
                {
                  "type": "element",
                  "name": "LienInterne",
                  "attributes": {
                    "LienPublication": "F14018",
                    "type": "Fiche d'information conditionnée",
                    "audience": "Particuliers"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "projet de transition professionnelle (PTP)"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence"
                },
                {
                  "type": "text",
                  "text": ", un congé de formation pouvant permettre de passer un examen."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Ce congé de formation permet le suivi d'une "
                },
                {
                  "type": "element",
                  "name": "LienExterne",
                  "attributes": {
                    "URL": "https://www.moncompteformation.gouv.fr/espace-public/pourquoi-choisir-une-formation-certifiante"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "formation certifiante"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " et peut impliquer de passer un examen pour la validation des compétences et des connaissances liées à cette formation."
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Ce congé de formation peut être pris en charge par une commission régionale appelée "
                },
                {
                  "type": "element",
                  "name": "Expression",
                  "children": [
                    {
                      "type": "text",
                      "text": "association Transitions Pro."
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Paragraphe",
              "children": [
                {
                  "type": "text",
                  "text": "Les pratiques liées à ce congé pour examen peuvent"
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": " varier"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " d'une commission à l'autre. Il est donc "
                },
                {
                  "type": "element",
                  "name": "MiseEnEvidence",
                  "children": [
                    {
                      "type": "text",
                      "text": "conseillé de se rapprocher"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": " d'elle pour connaitre la démarche à suivre."
                }
              ]
            },
            {
              "type": "element",
              "name": "OuSAdresser",
              "attributes": {
                "ID": "R39859",
                "sve": "non",
                "type": "National"
              },
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Commissions paritaires interprofessionnelles régionales (CPIR)"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "RessourceWeb",
                  "attributes": {
                    "URL": "https://travail-emploi.gouv.fr/formation-professionnelle/acteurs-cadre-et-qualite-de-la-formation-professionnelle/cpir"
                  }
                },
                {
                  "type": "element",
                  "name": "Source",
                  "attributes": {
                    "ID": "R30661"
                  },
                  "children": [
                    {
                      "type": "text",
                      "text": "Ministère chargé du travail"
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "name": "Complement",
              "children": [
                {
                  "type": "element",
                  "name": "Titre",
                  "children": [
                    {
                      "type": "text",
                      "text": "Connaître les règles de financement du permis de conduire avec le CPF"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Paragraphe",
                  "children": [
                    {
                      "type": "text",
                      "text": "La situation varie selon le type de permis qui vous intéresse :"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "BlocCas",
                  "attributes": {
                    "affichage": "radio"
                  },
                  "children": [
                    {
                      "type": "element",
                      "name": "Cas",
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Voiture ou moto"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "L’utilisation du CPF est possible si les conditions suivantes sont remplies :"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Liste",
                          "attributes": {
                            "type": "puce"
                          },
                          "children": [
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "L'obtention du permis de conduire contribue à la réalisation de votre projet professionnel ou à favoriser la sécurisation de votre parcours professionnel"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Liste",
                          "attributes": {
                            "type": "puce"
                          },
                          "children": [
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "La préparation aux épreuves du permis est co-financée par un tiers (employeur, opérateur de compétences, "
                                    },
                                    {
                                      "type": "element",
                                      "name": "LienInterne",
                                      "attributes": {
                                        "LienPublication": "R63450",
                                        "type": "Acronyme"
                                      },
                                      "children": [
                                        {
                                          "type": "text",
                                          "text": "Cnam"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "text",
                                      "text": ", "
                                    },
                                    {
                                      "type": "element",
                                      "name": "LienIntra",
                                      "attributes": {
                                        "LienID": "R1088",
                                        "type": "Définition de glossaire"
                                      },
                                      "children": [
                                        {
                                          "type": "text",
                                          "text": "collectivité territoriale"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "text",
                                      "text": "…) à hauteur au moins de "
                                    },
                                    {
                                      "type": "element",
                                      "name": "Valeur",
                                      "children": [
                                        {
                                          "type": "text",
                                          "text": "100 €"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "text",
                                      "text": ". Cette condition ne s’applique pas si vous êtes demandeur d’emploi"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "Vous n'avez pas de permis de conduire en cours de validité. Par exemple, si vous avez un permis B en cours de validité, vous ne pouvez pas utiliser votre CPF pour financer le permis A1."
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "Vous ne faites pas l'objet d'une suspension de permis de conduire ou d'une interdiction de demander un permis de conduire."
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "ASavoir",
                          "children": [
                            {
                              "type": "element",
                              "name": "Titre",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "À savoir"
                                }
                              ]
                            },
                            {
                              "type": "element",
                              "name": "Paragraphe",
                              "children": [
                                {
                                  "type": "text",
                                  "text": "Vous pouvez aussi utiliser votre CPF pour financer "
                                },
                                {
                                  "type": "element",
                                  "name": "LienInterne",
                                  "attributes": {
                                    "LienPublication": "F2826",
                                    "type": "Fiche d'information conditionnée",
                                    "audience": "Particuliers"
                                  },
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "l'apprentissage anticipé de la conduite (AAC) concernant le permis B"
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "text": " en présence d’un financement par un tiers."
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Cas",
                      "children": [
                        {
                          "type": "element",
                          "name": "Titre",
                          "children": [
                            {
                              "type": "text",
                              "text": "Catégories du groupe lourd (transport routier ou collectif)"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Paragraphe",
                          "children": [
                            {
                              "type": "text",
                              "text": "Les conditions suivantes doivent être remplies pour utiliser le CPF :"
                            }
                          ]
                        },
                        {
                          "type": "element",
                          "name": "Liste",
                          "attributes": {
                            "type": "puce"
                          },
                          "children": [
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "L'obtention du permis de conduire contribue à la réalisation de votre projet professionnel ou à favoriser la sécurisation de votre parcours professionnel"
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "element",
                              "name": "Item",
                              "children": [
                                {
                                  "type": "element",
                                  "name": "Paragraphe",
                                  "children": [
                                    {
                                      "type": "text",
                                      "text": "Vous ne faites pas l'objet d'une suspension de permis de conduire ou d'une interdiction de demander un permis de conduire."
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "ASavoir",
                  "children": [
                    {
                      "type": "element",
                      "name": "Titre",
                      "children": [
                        {
                          "type": "text",
                          "text": "À savoir"
                        }
                      ]
                    },
                    {
                      "type": "element",
                      "name": "Paragraphe",
                      "children": [
                        {
                          "type": "text",
                          "text": "Une page est consacrée aux "
                        },
                        {
                          "type": "element",
                          "name": "LienInterne",
                          "attributes": {
