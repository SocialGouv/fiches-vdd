                  "children": [
                    {
                      "type": "text",
                      "text": "Incidents de paiement"
                    }
                  ]
                },
                {
                  "type": "element",
                  "name": "Theme",
                  "attributes": {
                    "ID": "N19803"
                  },
                  "children": [
                    {
                      "type": "element",
