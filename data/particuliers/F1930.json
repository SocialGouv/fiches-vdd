                      "children": [
                        {
                          "type": "text",
                          "text": "Argent - Impôts - Consommation"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "element",
          "name": "QuiPeutMAider",
          "attributes": {
            "ID": "R16526",
            "sve": "non",
            "type": "Local"
          },
          "children": [
            {
              "type": "element",
              "name": "Titre",
              "children": [
                {
                  "type": "text",
                  "text": "Info Banque - Assurance"
                }
              ]
            },
